{
  "manifest_version": 3,
  "name": "Chrome Rectangle Open Links",
  "version": "0.1.0",
  "description": "矩形選択した範囲内のリンクを重複除去して別タブで一括表示する拡張機能",
  "permissions": ["activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "矩形選択でリンク一括表示"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
